#!/usr/bin/env bash
#
# Script for syncing all of my projects with the appropriate version control systems.
#
# Author: Nat Welch (nat@natwelch.com)

# First Param is directory name
sync_dir () {
  f=$1

  if [ -d $PROJ$f ]; then
    echo "--------> $f"
    cd $PROJ$f;
    rm -f .DS_Store
    if [ -d $PROJ$f/.git/ ]; then
      git fetch --prune
      upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null)
      if [ -n "$upstream" ] && ! git rev-parse --verify --quiet "$upstream" >/dev/null; then
        remote=${upstream%%/*}
        default=$(git symbolic-ref --short "refs/remotes/$remote/HEAD" 2>/dev/null) \
          || { git remote set-head "$remote" -a >/dev/null 2>&1 && default=$(git symbolic-ref --short "refs/remotes/$remote/HEAD" 2>/dev/null); }
        if [ -n "$default" ]; then
          echo "Upstream $upstream is gone; switching to ${default#$remote/}."
          git checkout "${default#$remote/}"
        fi
      fi
      git pull
      git status -sb
      return 0;
    elif [ -d $PROJ$f/.svn/ ]; then
      svn up
      return 0;
    else
      return 1;
    fi
  fi;
}

PROJ=~/Projects/
if [ -d $PROJ ]; then
  echo "# ~/Projects --------------------------------------------------------------------------------"
  for e in $(ls $PROJ | sort -f); do
    sync_dir $e
    if [ $? -eq 1 ]; then
      echo "No known version control."
    fi
  done;
fi

PROJ=~/Sites/
if [ -d $PROJ ]; then
  echo "# ~/Sites -----------------------------------------------------------------------------------"
  for e in $(ls $PROJ | sort -f); do
    sync_dir $e
    if [ $? -eq 1 ]; then
      echo "No known version control."
    fi
  done;
fi

PROJ=~/Work/
if [ -d $PROJ ]; then
  echo "# ~/Work ------------------------------------------------------------------------------------"
  for e in $(ls $PROJ | sort -f); do
    sync_dir $e
    if [ $? -eq 1 ]; then
      echo "No known version control."
    fi
  done;
fi

PROJ=~/HFP/
if [ -d $PROJ ]; then
  echo "# ~/HFP ------------------------------------------------------------------------------------"
  for e in $(ls $PROJ | sort -f); do
    sync_dir $e
    if [ $? -eq 1 ]; then
      echo "No known version control."
    fi
  done;
fi

echo "All Done!"
